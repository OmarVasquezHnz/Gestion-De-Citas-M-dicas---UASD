PORT=3000

# Opcion 1: SMTP generico
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# Opcion 2: Gmail simplificado
# EMAIL_USER=tu_correo@gmail.com
# EMAIL_PASS=tu_app_password

MAIL_FROM=Centro Medico UASD <tu_correo@gmail.com>

# Opcion 3: API Resend (sin SMTP/Gmail)
# RECOMENDADO para evitar App Password de Gmail
RESEND_API_KEY=

# Opcion 4: API Brevo (sin activacion SMTP)
BREVO_API_KEY=

# Base de datos (Supabase) para Netlify Functions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_STORAGE_TABLE=app_storage